# AgWebfull - Variáveis de Ambiente
# Baseado no agency-agents-app (MIT) por Michael Sitarzewski
# Adaptado para SaaS web por Webfull (https://webfull.com.br)

# Nome do aplicativo (exibido na UI)
PUBLIC_APP_NAME=AgWebfull

# URL do catálogo de agentes (repositório GitHub ou endpoint)
PUBLIC_CATALOG_SOURCE_URL=https://github.com/msitarzewski/agency-agents

# URL base da aplicação
PUBLIC_BASE_URL=https://agwebfull.webfullvps.com.br

# Porta do servidor (produção)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# Versão do app (gerada automaticamente no build)
PUBLIC_APP_VERSION=0.1.0
